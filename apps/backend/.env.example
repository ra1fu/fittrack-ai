DJANGO_SECRET_KEY=change-me-in-local-env-at-least-32-characters
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=false
DATABASE_URL=
LOG_LEVEL=INFO
DRF_AUTH_THROTTLE_RATE=30/min
DRF_AI_PHOTO_UPLOAD_THROTTLE_RATE=10/min
NUTRITION_AI_PHOTO_MAX_BYTES=5242880
NUTRITION_AI_PHOTO_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
NUTRITION_AI_PHOTO_PROVIDER=disabled
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
NUTRITION_AI_PHOTO_HTTP_ENDPOINT=
NUTRITION_AI_PHOTO_HTTP_API_KEY=
NUTRITION_AI_PHOTO_HTTP_TIMEOUT_SECONDS=20
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_TIMEOUT_SECONDS=10
OPEN_FOOD_FACTS_USER_AGENT=FitTrackAI/0.1 (contact@example.com)
